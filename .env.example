DATABASE_URL=postgresql://harmony:harmony@localhost:5433/harmony_paws
PORT=3000
JWT_SECRET=dev-jwt-secret-change-in-production
JWT_REFRESH_SECRET=dev-jwt-refresh-secret-change-in-production
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
MINIO_ENDPOINT=http://localhost:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_REGION=us-east-1
# Optional: single physical bucket (Hetzner). Logical buckets (dogs, users, …)
# are stored as key prefixes: dogs/{key}.jpeg. Omit locally — MinIO uses
# separate buckets created by docker-compose minio-init.
# MINIO_BUCKET_NAME=harmony-paws-staging-media
# Virtual-hosted URLs on Hetzner (default true = path-style for local MinIO).
# MINIO_FORCE_PATH_STYLE=false
EXPO_ACCESS_TOKEN=
# Comma-separated list of allowed origins. "*" is rejected because credentials
# are enabled (e.g. http://localhost:8081,https://app.harmonypaws.com).
CORS_ORIGIN=http://localhost:8081

# Google OAuth (Sign-In mobile) — OAuth 2.0 Client IDs from Google Cloud Console.
# Scopes required on consent screen: openid, email, profile.
# Service accounts are NOT used for Sign-In; create Web/iOS/Android OAuth clients.
GOOGLE_WEB_CLIENT_ID=
GOOGLE_IOS_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=

# Apple Sign-In — enable capability on App ID com.harmonypaws in Apple Developer.
APPLE_CLIENT_ID=com.harmonypaws
APPLE_TEAM_ID=QHF49Y88XV

# RevenueCat (server)
REVENUECAT_API_SECRET_KEY=
# Required. The webhook refuses requests (401) when this is unset, otherwise
# anyone could call it to grant premium. Must match the Authorization header
# configured in the RevenueCat dashboard.
REVENUECAT_WEBHOOK_AUTHORIZATION=
REVENUECAT_PREMIUM_ENTITLEMENT_ID=premium

# Resend (transactional + admin broadcast)
RESEND_API_KEY=
# Verified sender on your Resend domain (not onboarding@resend.dev in production)
RESEND_FROM_EMAIL=Harmony Paws <notifications@harmony-paws.com>
# Inbox for mobile reports (bug, signalements, contact)
SUPPORT_EMAIL=support@harmony-paws.com
